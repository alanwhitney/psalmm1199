# Supabase
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Bible API (api.bible) - get a free key at https://scripture.api.bible
BIBLE_API_KEY=your_api_bible_key

# Bible API IDs for KJV and NKJV
# KJV: de4e12af7f28f599-02
# NKJV: requires api.bible account - search their library for the correct ID
BIBLE_API_KJV_ID=de4e12af7f28f599-02
BIBLE_API_NKJV_ID=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
